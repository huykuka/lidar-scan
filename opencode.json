{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "instructions": [
    "AGENTS.md"
  ],
  "agent": {
    "compaction": {
      "model": "github-copilot/claude-haiku-4.5"
    },
    "plan": {
      "disable": true,
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow"
        }
      }
    }
  },
  "tools": {
    "chrome-devtools*": true,
    "synergy*": true,
    "gitnexus*": true
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true
    },
    "synergy": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@synergy-design-system/mcp"
      ],
      "enabled": true
    },
    "gitnexus": {
      "type": "local",
      "command": [
        "gitnexus",
        "mcp"
      ],
      "enabled": true
    }
  }
}
