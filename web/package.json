{
  "name": "LiDAR Studio",
  "version": "1.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0",
    "build": "ng build",
    "build:backend": "DEPLOY_BACKEND_STATIC=1 ng build --configuration production && node scripts/deploy-to-backend.mjs",
    "watch": "ng build --watch --configuration development",
