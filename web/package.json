    "@angular/platform-browser": "^22.0.4",
    "@angular/router": "^22.0.4",
    "@monogrid/gainmap-js": "^3.4.0",
    "@ngneat/until-destroy": "^10.0.0",
    "@pmndrs/vanilla": "^1.25.0",
    "@synergy-design-system/angular": "^3.16.0",
    "@synergy-design-system/assets": "^2.1.3",
    "@synergy-design-system/components": "^3.16.0",
    "@synergy-design-system/fonts": "^1.0.8",
