{
  "name": "web",
  "version": "1.0.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0",
    "build": "ng build",
    "build:backend": "DEPLOY_BACKEND_STATIC=1 ng build --configuration production && node scripts/deploy-to-backend.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "@angular/animations": "^22.0.2",
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/router": "^22.0.2",
    "@ngneat/until-destroy": "^10.0.0",
    "@synergy-design-system/angular": "^3.15.5",
    "@synergy-design-system/assets": "^2.1.2",
    "@synergy-design-system/components": "^3.15.5",
    "@synergy-design-system/fonts": "^1.0.7",
    "@synergy-design-system/styles": "^2.1.1",
    "@synergy-design-system/tokens": "^3.15.5",
    "echarts": "^6.1.0",
    "jszip": "^3.10.1",
    "rxjs": "~7.8.0",
    "three": "^0.183.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.3",
    "@angular/cli": "^22.0.3",
    "@angular/compiler-cli": "^22.0.2",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/jszip": "^3.4.0",
    "@types/three": "^0.183.1",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "tslib": "^2.3.0",
    "typescript": "~6.0.3",
    "vitest": "^4.0.8"
  }
}